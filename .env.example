# =====================================================================
# Digital M — configuration & keys
# Copy this file to `.env.local` and fill in the values there.
# `.env.local` is gitignored and is the ONLY place real secrets live.
# After changing server-side values, restart the app to pick them up.
# =====================================================================

# ---- Site ----------------------------------------------------------
# Public base URL. Staging: https://d3v.digitalm.eu  Production: https://digitalm.eu
# (Changing this is build-time: rebuild after editing.)
NEXT_PUBLIC_SITE_URL=https://d3v.digitalm.eu

# ---- Contact form (SMTP) ------------------------------------------
# SMTP credentials for the mailbox that sends contact-form email.
# Leave SMTP_HOST blank and the form gracefully falls back to a
# prefilled "email us directly" link.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465 (implicit TLS)
SMTP_USER=
SMTP_PASS=
CONTACT_FORM_TO=contact@digitalm.eu
CONTACT_FORM_FROM=contact@digitalm.eu

# ---- AI assistant (on-site chat — OpenAI, matches CAFRO) ----------
OPENAI_API_KEY=
OPENAI_MODEL_CHAT=gpt-4.1-mini
AI_DEFAULT_PROVIDER_PUBLIC=openai
AI_DEFAULT_PROVIDER_MEMBER=openai

# ---- Facebook Messenger bot (same brain as on-site chat; reuses OPENAI_API_KEY) ----
# Custom Messenger bot at /api/messenger. Requires a healthy Meta account:
#   1. Meta for Developers → create app → add the "Messenger" product.
#   2. Generate a Page access token for the Digital M Page → MESSENGER_PAGE_TOKEN.
#   3. App Settings → copy the App Secret → MESSENGER_APP_SECRET (verifies webhook signatures).
#   4. MESSENGER_VERIFY_TOKEN: any random string; enter the same value in the Meta
#      webhook config. Webhook URL: https://digitalm.eu/api/messenger (subscribe to "messages").
#   5. App review for the pages_messaging permission to serve non-admins.
MESSENGER_VERIFY_TOKEN=
MESSENGER_PAGE_TOKEN=
MESSENGER_APP_SECRET=

# ---- Analytics (optional, cookieless — leave blank to disable) -----
# Rebuild after changing (NEXT_PUBLIC_* are build-time). Cookieless = no consent gate.
#   Plausible:  SRC=https://plausible.io/js/script.js   DOMAIN=digitalm.eu
#   Umami:      SRC=https://<your-umami>/script.js       ID=<website-id>
NEXT_PUBLIC_ANALYTICS_SRC=
NEXT_PUBLIC_ANALYTICS_DOMAIN=
NEXT_PUBLIC_ANALYTICS_ID=

# ---- Booking (Google Calendar via a service account) --------------
# Server-side only. Create a Google Cloud service account, enable the
# Calendar API, grant it domain-wide delegation for the Calendar scope in
# the Workspace admin console, and point here. Leave GOOGLE_CALENDAR_KEY_FILE
# blank → the booking widget falls back to "propose a time → emails contact@".
GOOGLE_CALENDAR_KEY_FILE=
# Or inline the key JSON instead of a file path:
# GOOGLE_CALENDAR_KEY_JSON=
BOOKING_CALENDAR_ID=contact@digitalm.eu
BOOKING_IMPERSONATE=contact@digitalm.eu
# Optional: BOOKING_TZ (Europe/Paris), BOOKING_START_HOUR (9), BOOKING_END_HOUR (18),
# BOOKING_SLOT_MIN (30), BOOKING_BUFFER_MIN (30 — gap after each slot), BOOKING_DAYS (14), BOOKING_LEAD_MIN (120)

# Cloudflare Turnstile (diagnostic form anti-spam)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# SQLite enquiries DB (outside deploy tree)
ENQUIRIES_DB_PATH=/home/hermes/data/enquiries.db
